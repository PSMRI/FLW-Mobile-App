<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/profileDetailLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="10dp"
            >
            <ImageView
                android:id="@+id/iv_nhm_logo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="@string/cd_assam_nhm_logo"
                android:src="@drawable/logo_circle"
                />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/supervisor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/padding_small"
                app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:text="@string/name"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/subName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_small"
                app:layout_constraintTop_toBottomOf="@+id/supervisor_name"
                app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
                android:layout_marginStart="10dp"
                android:text="@string/str_supervisor"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textStyle="normal"
                android:gravity="center"
                />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/supervisorId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_small"
                app:layout_constraintTop_toBottomOf="@+id/subName"
                app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
                android:layout_marginStart="10dp"
                android:text="@string/id_details"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textStyle="normal"
                android:gravity="center"
                />
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                android:layout_marginEnd="20dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:cardBackgroundColor="@color/md_theme_dark_inversePrimary"
                app:layout_constraintTop_toTopOf="@+id/supervisorId">
                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit"/>
            </androidx.cardview.widget.CardView>



        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/contactInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/padding_small"
            android:paddingBottom="@dimen/padding_small"
            app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:text="@string/contact_info"
            app:layout_constraintStart_toStartOf="parent"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="normal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/profileDetailLayout" />

        <androidx.cardview.widget.CardView
            android:id="@+id/mobileCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/contactInfo"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_call_icon"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/icon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:text="@string/mobile_number"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </RelativeLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/emailCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/mobileCard"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/emailIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/baseline_email_24"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/emailIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/emailtvTitle"
                        android:text="@string/email"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/emailtvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </RelativeLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/districCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/emailCard"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/districIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/baseline_location_on_24"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/districIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/districtvTitle"
                        android:text="@string/district"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/districtvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/blockCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/districCard"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/blockIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_home"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/blockIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/blocktvTitle"
                        android:text="@string/block"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/blocktvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </RelativeLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/subcenterCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/blockCard"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/subcenterIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_home"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/subcenterIcon"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/subcentertvTitle"
                        android:text="@string/str_subcenter"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/subcentertvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/bankDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/padding_small"
            android:visibility="gone"
            android:paddingBottom="@dimen/padding_small"
            app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:text="@string/bank_details"
            app:layout_constraintStart_toStartOf="parent"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="normal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/subcenterCard" />

        <androidx.cardview.widget.CardView
            android:id="@+id/accountCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/bankDetails"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            >

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/bankIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_bank_name"
                    />

                <LinearLayout
                    android:id="@+id/ttLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/bankIcon"
                    android:layout_marginStart="16dp"
                    >

                    <TextView
                        android:id="@+id/banktvTitle"
                        android:text="@string/bank_acc"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/banktvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/outline_keyboard_arrow_right_24"
                    android:layout_alignParentEnd="true"
                    />

                <View
                    android:id="@+id/underLine"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/ttLayout"
                    android:layout_marginStart="40dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/read_only"/>

                <ImageView
                    android:id="@+id/ifscIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_below="@+id/underLine"
                    android:layout_marginTop="10dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_bank_name"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:id="@+id/bottomLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/ifscIcon"
                    android:layout_marginTop="5dp"
                    android:layout_below="@+id/underLine"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/ifscTitle"
                        android:text="@string/ifsc_code"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/ifsctvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignRight="@+id/bottomLayout"
                    android:layout_below="@+id/underLine"
                    android:layout_marginTop="15dp"
                    android:src="@drawable/outline_keyboard_arrow_right_24"
                    android:layout_alignParentEnd="true"
                    />
            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/settingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/padding_small"
            android:paddingBottom="@dimen/padding_small"
            app:layout_constraintStart_toEndOf="@+id/iv_nhm_logo"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:text="@string/app_settings"
            app:layout_constraintStart_toStartOf="parent"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textStyle="normal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/accountCard" />

        <androidx.cardview.widget.CardView
            android:id="@+id/appSettingCard"
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/settingText"
            app:cardCornerRadius="8dp"
            android:layout_marginStart="20dp"
            android:background="@color/md_theme_light_onError"
            android:layout_marginEnd="20dp"
            >

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingRight="12dp"
                android:paddingLeft="12dp">



                <ImageView
                    android:id="@+id/logoutIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_below="@+id/underLineTwo"
                    android:layout_marginTop="10dp"
                    android:tint="@color/md_theme_dark_inversePrimary"
                    android:src="@drawable/ic_logout"
                    android:layout_centerVertical="true"/>

                <LinearLayout
                    android:id="@+id/logoutlayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/logoutIcon"
                    android:layout_marginTop="5dp"
                    android:layout_below="@+id/underLineTwo"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/logoutTitle"
                        android:text="@string/logout"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/logoutTvValue"
                        android:text=""
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignRight="@+id/logoutlayout"
                    android:layout_below="@+id/underLineTwo"
                    android:layout_marginTop="15dp"
                    android:src="@drawable/outline_keyboard_arrow_right_24"
                    android:layout_alignParentEnd="true"
                    />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            app:layout_constraintTop_toBottomOf="@+id/appSettingCard"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
